<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/ticket_background"
    tools:context=".presentation.ticket.TicketDetailActivity">

    <!-- 상단 헤더 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="142dp"
        android:background="@color/white"
        android:elevation="2dp"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:gravity="center_vertical"
        android:paddingVertical="20dp">

        <TextView
            android:id="@+id/performanceTitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text=""
            android:textColor="@color/ticket_text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/performanceInfoText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/ticket_text_secondary"
            android:textSize="16sp" />

    </LinearLayout>

    <!-- 티켓 탭 -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/ticketTabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:tabMode="scrollable"
        app:tabIndicatorColor="@color/ticket_primary"
        app:tabSelectedTextColor="@color/ticket_primary"
        app:tabTextColor="@color/ticket_text_secondary"/>

    <!-- 티켓 ViewPager -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/ticketViewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- 하단 여백 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:background="@color/ticket_background"/>

</LinearLayout>