<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ticket_background"
    android:orientation="vertical"
    tools:context=".presentation.ticket.TicketListActivity">



    <!-- 상단 헤더 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="91dp"
        android:background="@color/white"
        android:elevation="2dp"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingVertical="20dp"
        android:paddingTop="100dp">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="72dp"
            android:layout_marginEnd="12dp"
            android:scaleType="centerInside"
            android:src="@drawable/logo" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="71dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:text="나의 티켓"
            android:textColor="@color/ticket_text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/ticketCountText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:text="총 매"
            android:textColor="@color/ticket_text_secondary"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- 티켓이 없을 때 표시할 뷰 -->
    <LinearLayout
        android:id="@+id/emptyView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="40dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginBottom="16dp"
            android:alpha="0.5"
            android:src="@drawable/logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="아직 예매한 티켓이 없어요"
            android:textColor="@color/ticket_text_secondary"
            android:textSize="18sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="첫 공연을 예매해보세요!"
            android:textColor="@color/ticket_text_secondary"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- 티켓 리스트 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/ticketRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="595dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:padding="8dp"
        android:paddingBottom="80dp" />

    <!-- 하단 여백 (네비게이션 바 대응) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:background="@color/ticket_background" />

</LinearLayout>